import pandas as pd
df=pd.read_csv('student_data (1).csv')
df


# add columns name country
df['Country']='Bangladesh'
df


# create a new columns total mark 
df['Avg_mark']=(df['Algorithm Marks']+df['Data Structure Marks']+df['Python Marks'])/3
df


# Add a Grade columns 

def check(x):
    if x>=80:
        return "A+"
    else:
        return "No"

df['Grade']=df['Avg_mark'].apply(check)
df



